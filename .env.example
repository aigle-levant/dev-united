# Get your free key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Register an app at https://stackapps.com/apps/oauth/register
SOF_API_KEY=your_stackoverflow_api_key_here

# Generate a Personal Access Token (classic) at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# Find these in your Supabase project settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_public_key_here

PORT=your_port_number_here